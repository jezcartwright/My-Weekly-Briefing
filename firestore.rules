rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin allow-list. Edit to add admins.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jc@jezcartwright.com'
        ];
    }

    // Validate that a write only touches the unsubscribe fields and
    // doesn't change anything else. Used to allow anonymous unsubscribes.
    function isUnsubscribeOnlyWrite() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(['unsubscribed', 'unsubscribedAt'])
        && request.resource.data.unsubscribed == true;
    }

    match /users/{uid} {
  allow read, write: if request.auth != null && (
    request.auth.uid == uid ||
    request.auth.token.email == 'jc@jezcartwright.com'
  );
}


    // Contact-form messages: any signed-in user can create their own;
    // only the admin can read or manage them.
    match /messages/{msgId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000;
      allow read, update, delete: if isAdmin();
    }

    // Conversation threads: subscriber owns theirs; admin can access all.
    match /threads/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create, update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      match /messages/{msgId} {
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow create: if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow update, delete: if isAdmin();
      }
    }

    // Account deletion requests. Creating one triggers the processAccountDeletion
    // Cloud Function, which runs with admin privileges to erase the user's data
    // and sign-in. Admin can request deletion of anyone; a user can request their own.
    match /deletionRequests/{uid} {
      allow create: if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow read, delete: if isAdmin();
    }

    // Admin-initiated email-address changes. Creating one triggers the
    // processEmailChange Cloud Function (admin IAM), which updates the Auth
    // login email + Firestore copies and writes a status back for the UI.
    match /emailChangeRequests/{uid} {
      allow create, read, update, delete: if isAdmin();
    }

    // Admin-only send job queue
    match /adminSends/{jobId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      // Update allowed by service-account worker (which doesn't go through
      // these client rules — it uses IAM) and by admin (who can edit/abort).
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admin-initiated welcome (re)sends. Creating one triggers the
    // onWelcomeSendRequest Cloud Function, which clears welcomedAt and kicks
    // the welcome-send workflow; status is written back (IAM) for the UI.
    match /welcomeSends/{uid} {
      allow create, read, update, delete: if isAdmin();
    }
  }
}
