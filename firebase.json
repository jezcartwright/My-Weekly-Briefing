{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "**/.*",
      ".git/**",
      "**/.git/**",
      "**/node_modules/**",
      ".github/**",
      "*.md",
      "**/*.py",
      "functions/**"
    ]
  },
  "functions": { "source": "functions" },
  "firestore": { "rules": "firestore.rules" }
}
