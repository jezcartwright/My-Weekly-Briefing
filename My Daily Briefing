      why: "In a world of constant input and relentless busyness, genuine self-examination has become countercultural. Yet leaders who demonstrate deep self-awareness consistently make better decisions and sustain their performance over time.",
      insight: "Most leaders manage their outer world with great sophistication while leaving their inner world entirely unmanaged.",
      deeper: [
        "When did you last spend an hour — without input — examining your own motivations and assumptions?",
        "Peter Drucker's essay 'Managing Oneself' is the most practical translation of Socratic self-examination into leadership",
        "Ask your client: 'What do you know about yourself that you're not yet acting on?'"
      ]
    },
    {
      title: "Meaning Over Happiness",
      headline: "Viktor Frankl's insight that meaning sustains people through suffering that happiness cannot is essential knowledge for coaches.",
      why: "Research distinguishes between a meaningful life and a happy one — they often diverge. Challenging work is often not enjoyable but deeply fulfilling. Coaches who help clients optimise for meaning rather than comfort are doing more valuable and more durable work.",
      insight: "People can endure almost any 'how' if they have a strong enough 'why' — but chasing happiness without meaning leads to emptiness.",
      deeper: [
        "In what areas of your life are you optimising for comfort when you should be optimising for meaning?",
        "Viktor Frankl's 'Man's Search for Meaning' — if you haven't read it, stop everything",
        "Coach prompt: 'What would you do differently if you were optimising for meaning rather than security or status?'"
      ]
    },
    {
      title: "First Principles Thinking",
      headline: "Reasoning from fundamentals rather than analogy is the rarest and most valuable cognitive skill in leadership.",
      why: "Most people reason by analogy — 'this is like that, so we'll do what worked there.' First principles thinkers ask: what is actually true here, independent of precedent? This produces radical innovation and genuine strategic insight.",
      insight: "The constraints most leaders accept as given are often just assumptions that have never been examined — and examining them is where breakthroughs live.",
      deeper: [
        "Pick one 'obvious' constraint in your business. Ask: why is this true? Keep asking until you reach something genuinely fundamental.",
        "Shane Parrish's 'Clear Thinking' is the best modern resource on mental models for leaders",
        "Ask your client: 'What are you treating as impossible that might actually just be unfamiliar?'"
      ]
    }
  ]]
};

function getTopics(categoryId) {
  const sets = CONTENT[categoryId];
  if (!sets) return [];
  const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0)) / 86400000);
  return sets[dayOfYear % sets.length];
}

// Set date
document.getElementById('date-display').textContent = new Date().toLocaleDateString('en-US', {
  weekday: 'short', month: 'short', day: 'numeric', year: 'numeric'
});

let activeCat = CATEGORIES[0];
let openCard = null;

function renderTabs() {
  const tabs = document.getElementById('tabs');
  tabs.innerHTML = '';
  CATEGORIES.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'tab' + (cat.id === activeCat.id ? ' active' : '');
    btn.innerHTML = `<span class="tab-icon" style="color:${cat.color}">${cat.icon}</span>${cat.label}`;
    btn.style.borderBottomColor = cat.id === activeCat.id ? cat.color : 'transparent';
    btn.onclick = () => { activeCat = cat; openCard = null; renderTabs(); renderContent(); };
    tabs.appendChild(btn);
  });
}

function renderContent() {
  const scroll = document.getElementById('scroll');
  const topics = getTopics(activeCat.id);
  const ac = activeCat;

  scroll.innerHTML = `
    <div class="cat-intro">
      <span class="icon" style="color:${ac.color}">${ac.icon}</span>
      <div>
        <div class="cat-name" style="color:${ac.color}">${ac.label}</div>
        <div class="cat-desc">Four high-signal topics to keep you sharp today</div>
      </div>
    </div>
    <div class="topic-list">
      ${topics.map((t, i) => `
        <div class="topic-card${openCard === i ? ' open' : ''}" id="card-${i}">
          <div class="topic-header" onclick="toggleCard(${i})">
            <div style="display:flex;align-items:flex-start;gap:10px;flex:1">
              <span class="topic-num" style="color:${ac.color}">0${i+1}</span>
              <div class="topic-title-wrap">
                <div class="topic-title">${t.title}</div>
                <div class="topic-headline">${t.headline}</div>
              </div>
            </div>
            <div class="topic-toggle" style="color:${openCard===i ? ac.color : '#2a2a2a'}">+</div>
          </div>
          <div class="topic-body">
            <div class="two-col">
              <div>
                <div class="label">Why It Matters</div>
                <div class="body-text">${t.why}</div>
              </div>
              <div>
                <div class="label accent" style="color:${ac.color}">Key Insight</div>
                <div class="insight-text">"${t.insight}"</div>
              </div>
            </div>
            <div class="deeper" style="border-left-color:${ac.color}">
              <div class="label" style="margin-bottom:10px">Go Deeper →</div>
              ${t.deeper.map(d => `
                <div class="deeper-item">
                  <span class="deeper-arrow" style="color:${ac.color}">▸</span>
                  <span class="deeper-text">${d}</span>
                </div>
              `).join('')}
            </div>
          </div>
        </div>
      `).join('')}
    </div>
  `;
  scroll.scrollTop = 0;
}

function toggleCard(i) {
  openCard = openCard === i ? null : i;
  renderContent();
}

// Init
renderTabs();
renderContent();
</script>

</body>
</html>
