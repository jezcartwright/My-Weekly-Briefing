<style>
  :root {
    --bg: #0D0D0D;
    --surface: #111111;
    --surface2: #161616;
    --border: #1E1E1E;
    --border2: #252525;
    --text: #EAE4D8;
    --text2: #A09890;
    --text3: #5A5248;
    --gold: #C9A84C;
    --safe-top: env(safe-area-inset-top, 44px);
    --safe-bottom: env(safe-area-inset-bottom, 20px);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--text); font-family: 'IBM Plex Mono', monospace; }

/* App shell */
#app { display: flex; flex-direction: column; height: 100vh; height: 100dvh; }

/* Header */
#header {
padding: calc(var(–safe-top) + 14px) 22px 14px;
border-bottom: 1px solid var(–border);
display: flex; justify-content: space-between; align-items: flex-end;
flex-shrink: 0;
background: var(–bg);
}
#header h1 {
font-family: ‘Playfair Display’, serif;
font-size: 26px; font-weight: 700;
color: #F4EEE4; letter-spacing: -0.03em; line-height: 1;
}
#header .sub { font-size: 9px; letter-spacing: 0.22em; color: var(–text3); text-transform: uppercase; margin-bottom: 5px; }
#header .date-block { text-align: right; }
#header .date { font-size: 10px; color: var(–text3); line-height: 1.6; }
#header .badge { font-size: 9px; color: var(–gold); letter-spacing: 0.12em; margin-top: 2px; }

/* Tab bar */
#tabs {
display: flex; overflow-x: auto; border-bottom: 1px solid var(–border);
flex-shrink: 0; background: var(–bg);
scrollbar-width: none;
}
#tabs::-webkit-scrollbar { display: none; }
.tab {
flex-shrink: 0; padding: 11px 16px 10px;
font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
color: var(–text3); background: none; border: none; cursor: pointer;
display: flex; align-items: center; gap: 6px;
border-bottom: 2px solid transparent;
transition: color 0.2s, border-color 0.2s;
white-space: nowrap;
}
.tab.active { color: var(–text); }
.tab .tab-icon { font-size: 12px; }

/* Scroll area */
#scroll {
flex: 1; overflow-y: auto; overflow-x: hidden;
-webkit-overflow-scrolling: touch;
padding: 20px 18px calc(var(–safe-bottom) + 20px);
}

/* Category intro */
.cat-intro {
display: flex; align-items: center; gap: 12px;
margin-bottom: 20px; padding-bottom: 16px;
border-bottom: 1px solid var(–border);
animation: fadeUp 0.3s ease both;
}
.cat-intro .icon { font-size: 20px; }
.cat-intro .cat-name { font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 3px; }
.cat-intro .cat-desc { font-family: ‘Playfair Display’, serif; font-size: 13px; font-style: italic; color: var(–text2); line-height: 1.5; }

/* Topic cards */
.topic-list { display: flex; flex-direction: column; gap: 12px; }

.topic-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: 3px; overflow: hidden;
transition: border-color 0.2s, background 0.2s;
animation: fadeUp 0.35s ease both;
}
.topic-card:nth-child(1){animation-delay:0.05s}
.topic-card:nth-child(2){animation-delay:0.1s}
.topic-card:nth-child(3){animation-delay:0.15s}
.topic-card:nth-child(4){animation-delay:0.2s}
.topic-card.open { background: var(–surface2); }

.topic-header {
padding: 16px 18px; cursor: pointer;
display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;
-webkit-user-select: none; user-select: none;
}
.topic-num { font-size: 10px; opacity: 0.5; margin-right: 2px; flex-shrink: 0; margin-top: 2px; }
.topic-title-wrap { flex: 1; }
.topic-title {
font-family: ‘Playfair Display’, serif;
font-size: 16px; font-weight: 600; color: #F4EEE4;
letter-spacing: -0.01em; line-height: 1.3; margin-bottom: 6px;
}
.topic-headline { font-size: 12px; color: var(–text2); line-height: 1.6; font-style: italic; }
.topic-toggle {
font-size: 18px; color: var(–border2); flex-shrink: 0; margin-top: 1px;
transition: transform 0.25s, color 0.2s; line-height: 1;
}
.topic-card.open .topic-toggle { transform: rotate(45deg); }

/* Expanded content */
.topic-body {
display: none; padding: 0 18px 18px;
border-top: 1px solid var(–border);
padding-top: 16px;
}
.topic-card.open .topic-body { display: block; }

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
@media(max-width: 500px) { .two-col { grid-template-columns: 1fr; } }

.label {
font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
color: var(–text3); margin-bottom: 7px;
}
.label.accent { color: inherit; }

.body-text { font-size: 12px; color: var(–text2); line-height: 1.85; }
.insight-text {
font-family: ‘Playfair Display’, serif; font-style: italic;
font-size: 12px; color: #CEC6B6; line-height: 1.85;
}

/* Go deeper block */
.deeper {
background: #0A0A0A;
border-left: 2px solid;
padding: 13px 14px; border-radius: 1px;
margin-top: 4px;
}
.deeper-item { display: flex; gap: 8px; margin-bottom: 8px; align-items: flex-start; }
.deeper-item:last-child { margin-bottom: 0; }
.deeper-arrow { font-size: 9px; margin-top: 3px; flex-shrink: 0; }
.deeper-text { font-size: 11px; color: #777; line-height: 1.75; }

@keyframes fadeUp {
from { opacity: 0; transform: translateY(10px); }
to   { opacity: 1; transform: none; }
}
</style>

</head>
